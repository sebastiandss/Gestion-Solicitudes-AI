---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopBar from "../components/TopBar.astro";
import NavigationTabs from "../components/NavigationTabs.astro";
import MisTramites from "../components/views/MisTramites.astro";
import NuevaSolicitud from "../components/views/NuevaSolicitud.astro";
import ProgramasDisponibles from "../components/views/ProgramasDisponibles.astro";
import Notificaciones from "../components/views/Notificaciones.astro";
---

<BaseLayout title="BeneficIA Social — Portal Personal">
  <TopBar
    initials="U"
    name="Usuario"
    idInfo="Afiliado"
  />

  <NavigationTabs />

  <MisTramites />
  <NuevaSolicitud />
  <ProgramasDisponibles />
  <Notificaciones />

  <script is:inline>
    // Si no está el flag de sesión, mandarlo al login
    if (localStorage.getItem("isLoggedIn") !== "true") {
      window.location.href = "/login";
    }
  </script>
</BaseLayout>
